{
  "name": "iptv-org.github.io",
  "type": "module",
  "private": true,
  "scripts": {
    "act:update": "act workflow_dispatch -W .github/workflows/update.yml",
    "api:load": "tsx src/commands/api/load.ts",
    "dev": "cross-env NODE_OPTIONS=--max_old_space_size=5096 vite dev --host",
    "build": "cross-env NODE_OPTIONS=--max_old_space_size=5096 vite build",
    "preview": "vite preview --host",
    "prepare": "svelte-kit sync",
    "postinstall": "npm run api:load",
    "postbuild": "npx svelte-sitemap -d https://iptv-org.github.io -o docs",
    "test": "vitest run",
    "lint": "eslint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@freearhey/core": "^0.16.1",
    "@floating-ui/dom": "^1.7.6",
    "@iptv-org/sdk": "^1.4.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/cli-progress": "^3.11.6",
    "@types/qs": "^6.15.0",
    "@zerodevx/svelte-toast": "^0.9.6",
    "cli-progress": "^3.12.0",
    "country-flag-icons": "^1.6.16",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.20",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "iptv-playlist-generator": "^0.1.5",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "svelte-simple-modal": "^2.0.0",
    "svelte-sitemap": "^3.1.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vite-plugin-mkcert": "^2.0.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "esbuild": "0.28.0",
    "glob": "13.0.6",
    "cookie": "1.1.1"
  }
}
